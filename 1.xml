<Module>
<ModulePrefs title="classroom" />
<Content type="html"><![CDATA[


<!DOCTYPE html>
<html lang="en-us">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
    <style>
        canvas:focus { outline: none; }
        html, body {
            padding: 0; margin: 0; overflow: hidden;
            -webkit-touch-callout: none; -webkit-user-select: none;
            user-select: none; height: 100%; background: #000;
        }
        #loading-cover {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: #000; z-index: 10; display: flex; justify-content: center; align-items: center;
            flex-direction: column;
        }
        .spinner {
            border: 4px solid rgba(255, 255, 255, 0.3);
            width: 36px; height: 36px; border-radius: 50%;
            border-left-color: #fff; animation: spin 1s linear infinite;
        }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        #unity-progress-bar-empty { width: 30%; height: 10px; background: #222; margin-top: 20px; display: none; border-radius: 5px; overflow: hidden; }
        #unity-progress-bar-full { width: 0%; height: 100%; background: #007EBD; transition: width 0.2s; }
        #chunk-status { color: #555; font-size: 12px; margin-top: 10px; font-family: sans-serif; }
    </style>

    <script>
        window.YaGames = {
            init: function() {
                return new Promise((resolve) => {
                    const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
                    const mockSDK = {
                        deviceInfo: { type: isMobile ? 'mobile' : 'desktop', isMobile: () => isMobile, isDesktop: () => !isMobile, isTablet: () => false, isTV: () => false },
                        screen: { fullscreen: { status: 'on', request: () => {}, exit: () => {} } },
                        environment: { app: { id: 'knife' }, browser: { lang: 'tr' }, i18n: { lang: 'tr', tld: 'com' } },
                        adv: {
                            showFullscreenAdv: (c) => { c.callbacks?.onOpen?.(); setTimeout(() => { nowFullAdOpen = false; c.callbacks?.onClose?.(true); }, 100); },
                            showRewardedVideo: (c) => { c.callbacks?.onOpen?.(); setTimeout(() => { c.callbacks?.onRewarded?.(); c.callbacks?.onClose?.(); }, 100); }
                        },
                        features: { LoadingAPI: { ready: function() { console.log("Mock: Game Ready API Called"); } } },
                        getPlayer: () => Promise.resolve({ getName: () => "Player", getUniqueID: () => "uid-123", isAuthorized: () => true, getMode: () => "lite", setData: () => Promise.resolve(), getData: () => Promise.resolve({}), getStats: () => Promise.resolve({}) })
                    };
                    resolve(mockSDK);
                });
            }
        };

        function LogStyledMessage(message, style) { console.log('%c' + message, style || 'color: #FFDF73; background-color: #454545'); }
        let nowFullAdOpen = false;
        let initGame = false;

        function InitGame() {
            initGame = true;
            console.log("Mock: InitGame triggered from Unity");
            setTimeout(function () { if (nowFullAdOpen == true) { YG2Instance('OpenInterAdv'); } }, 100);
        }
    </script>
</head>
<body class="dark">
    <div id="unity-container">
        <canvas id="unity-canvas" tabindex="-1" style="width: 100%; height: 100%; position: absolute;"></canvas>
    </div>
    <div id="loading-cover">
        <div class="spinner" id="loading-spinner"></div>
        <div id="chunk-status">G+...</div>
        <div id="unity-progress-bar-empty">
            <div id="unity-progress-bar-full"></div>
        </div>
    </div>

    <script>
        const buildUrl = "https://cdn.jsdelivr.net/gh/schoolflashx/x9o9x8@main/Build";
        const loaderUrl = buildUrl + "/kBuild.loader.js";
        
        // Parça bilgileri
        const wasmPartCount = 4; // 32.3MB / 8MB = 4.03 -> 5 parça
        const wasmBaseName = buildUrl + "/kBuild.wasm.br.part";

        const config = {
            dataUrl: buildUrl + "/kBuild.data.br",
            frameworkUrl: buildUrl + "/kBuild.framework.js",
            codeUrl: "", // Dinamik olarak doldurulacak
            streamingAssetsUrl: "StreamingAssets",
            companyName: "DefaultCompany",
            productName: "knife",
            productVersion: "0.1.0"
        };

        const canvas = document.querySelector("#unity-canvas");
        const loadingCover = document.querySelector("#loading-cover");
        const progressBarEmpty = document.querySelector("#unity-progress-bar-empty");
        const progressBarFull = document.querySelector("#unity-progress-bar-full");
        const spinner = document.querySelector('#loading-spinner');
        const chunkStatus = document.querySelector('#chunk-status');

        let ygGameInstance = null;
        let ysdk = null;

        function YG2Instance(method, arg) {
            if (ygGameInstance) {
                ygGameInstance.SendMessage('YG2Instance', method, arg !== undefined ? arg : "");
            }
        }

        // Parçaları indirip birleştiren fonksiyon
        async function fetchAndCombineWasm() {
            const chunks = [];
            for (let i = 0; i < wasmPartCount; i++) {
                chunkStatus.innerText = `G+: ... ${i + 1}/${wasmPartCount}`;
                const response = await fetch(`${wasmBaseName}${i}`);
                if (!response.ok) throw new Error(`Parça ${i} indirilemedi!`);
                const arrayBuffer = await response.arrayBuffer();
                chunks.push(arrayBuffer);
            }
            
            chunkStatus.innerText = "Parçalar birleştiriliyor...";
            const combinedBlob = new Blob(chunks, { type: "application/octet-stream" });
            return URL.createObjectURL(combinedBlob);
        }

        async function InitYSDK() {
            try {
                ysdk = await YaGames.init();
                if (ygGameInstance) YG2Instance('InitSDKComplete');
                LogStyledMessage('Init YandexSDK Success (Mock)');
            } catch (e) {
                console.error('SDK Init Error: ', e);
            }

            try {
                // Unity'yi yüklemeden önce Wasm'ı hazırla
                const blobUrl = await fetchAndCombineWasm();
                config.codeUrl = blobUrl;
                chunkStatus.style.display = "none";
                LoadUnity();
            } catch (err) {
                chunkStatus.innerText = "Kritik Hata: Dosyalar yüklenemedi.";
                console.error(err);
            }
        }

        function LoadUnity() {
            const script = document.createElement("script");
            script.src = loaderUrl;
            script.onload = () => {
                createUnityInstance(canvas, config, (progress) => {
                    if (progress > 0) {
                        spinner.style.display = "none";
                        progressBarEmpty.style.display = "block";
                    }
                    progressBarFull.style.width = `${100 * Math.max(progress, 0.01)}%`;
                }).then((unityInstance) => {
                    ygGameInstance = unityInstance;
                    loadingCover.style.display = "none";
                }).catch(console.error);
            };
            document.body.appendChild(script);
        }

        // Diğer SDK fonksiyonları (RewardedAdvShow, InterAdvShow) aynı kalıyor...
        function RewardedAdvShow(id) {
            if(!ysdk) return;
            ysdk.adv.showRewardedVideo({
                callbacks: {
                    onOpen: () => YG2Instance('OpenRewardedAdv'),
                    onClose: () => { YG2Instance('CloseRewardedAdv'); window.focus(); },
                    onRewarded: () => YG2Instance('RewardAdv', id),
                    onError: () => { YG2Instance('ErrorRewardedAdv'); window.focus(); }
                }
            });
        }

        function InterAdvShow() {
            if(!ysdk) return;
            ysdk.adv.showFullscreenAdv({
                callbacks: {
                    onOpen: () => { nowFullAdOpen = true; YG2Instance('OpenInterAdv'); },
                    onClose: (shown) => { nowFullAdOpen = false; YG2Instance('CloseInterAdv', shown ? 'true' : 'false'); window.focus(); },
                    onError: () => { nowFullAdOpen = false; YG2Instance('ErrorInterAdv'); window.focus(); }
                }
            });
        }

        InitYSDK();
    </script>
    
    <!-- Sticky Bottom Center Ad (728x90) with Smooth Slide-Out and Reappearance -->
<style>
  /* Container: Bottom center, fixed, with overflow hidden */
  #ad-container {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: min(728px, calc(100% - 20px)); /* 728px, 10px margin on mobile */
    height: 90px;
    background: rgba(0, 0, 0, 0.90);
    display: none;
    z-index: 99999;
    border-radius: 0; /* Sharp corners */
    overflow: hidden;
    box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.45);
    box-sizing: border-box;
    transition: transform 0.5s ease-in-out; /* Smooth slide-in/out animation */
  }

  /* Slide-out animation */
  #ad-container.hidden {
    transform: translate(-50%, 100%); /* Slide down out of view */
  }

  #ad-iframe {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 745px; /* Updated width */
    height: 90px; /* Updated height */
    border: 0;
    display: block;
    overflow: hidden;
    pointer-events: auto;
    box-sizing: content-box;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  
  #ad-iframe::-webkit-scrollbar {
    display: none;
    width: 0;
    height: 0;
  }

  /* Close button with arrow */
  #close-ad {
    position: absolute;
    top: 6px;
    right: 8px;
    background: #ff4d4d;
    color: #fff;
    border: none;
    padding: 5px 9px;
    font-size: 13px;
    border-radius: 4px;
    cursor: not-allowed;
    opacity: 0.72;
    z-index: 100000;
    display: flex;
    align-items: center;
  }
  #close-ad.enabled {
    cursor: pointer;
    opacity: 1;
  }
  #close-ad::before {
    content: '↓'; /* Down arrow for bottom ad */
    margin-right: 4px;
  }

  /* Right mask for scrollbar */
  #ad-right-mask {
    position: absolute;
    top: 0;
    right: 0;
    width: 12px;
    height: 100%;
    pointer-events: none;
    background: linear-gradient(to right, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.9));
    z-index: 99999;
  }

  /* Mobile adjustments */
  @media (max-width: 440px) {
    #ad-container {
      width: calc(100% - 12px);
      left: 50%;
      transform: translateX(-50%);
      border-radius: 0; /* Sharp corners on mobile */
    }
    #ad-iframe {
      width: 728px;
    }
  }
</style>

<div id="ad-container" aria-hidden="true" role="dialog" aria-label="Advertisement">
  <iframe
    id="ad-iframe"
    src="https://script.google.com/macros/s/AKfycbw60Tp6nuqThxAuU8ZN1JIuPtjHoW2Uqq3fQy0CvrycN0O2AQwhRT5EDv73hh2FhXEF/exec"
    width="768px"
    height="95px"
    scrolling="no"
    frameborder="0"
    sandbox="allow-scripts allow-popups allow-same-origin"
  ></iframe>
  <button id="close-ad" disabled>Close (12)</button>
  <div id="ad-right-mask"></div>
</div>

<script>
  (function () {
    const showDelay = 2000; // 2 seconds delay before first show
    const countdownStart = 12; // 12 seconds countdown
    const reappearDelay = 150000; // 25 seconds before reappearance
    const adContainer = document.getElementById('ad-container');
    const closeBtn = document.getElementById('close-ad');

    function showAd() {
      // Show ad with smooth slide-in
      adContainer.style.display = 'block';
      adContainer.classList.remove('hidden');
      adContainer.setAttribute('aria-hidden', 'false');

      // Start countdown
      let timeLeft = countdownStart;
      closeBtn.textContent = `Close (${timeLeft})`;
      closeBtn.disabled = true;
      closeBtn.classList.remove('enabled');

      const t = setInterval(() => {
        timeLeft--;
        if (timeLeft > 0) {
          closeBtn.textContent = `Close (${timeLeft})`;
        } else {
          clearInterval(t);
          closeBtn.disabled = false;
          closeBtn.classList.add('enabled');
          closeBtn.textContent = 'Close ↓';
        }
      }, 1000);
    }

    // Initial ad show
    setTimeout(showAd, showDelay);

    // Close with animation and schedule reappearance
    closeBtn.addEventListener('click', () => {
      if (closeBtn.disabled) return;
      adContainer.classList.add('hidden');
      adContainer.setAttribute('aria-hidden', 'true');
      // Schedule reappearance without removing or reloading iframe
      setTimeout(showAd, reappearDelay);
    });
  })();
</script>

</body>
</html>

